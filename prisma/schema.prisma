generator client {
  provider     = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  rooms     Room[]
}

model Room {
  id             String   @id @default(uuid())
  name           String
  collectionName String   @unique @default(uuid())
  userId         String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  files          File[]
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  quizRoom QuizRoom[]
  chatRoom ChatRoom[]
}

model QuizRoom {
  id             String   @id @default(uuid())
  name String @default("Quiz")
  roomid String @unique
  room Room @relation(fields: [roomid], references: [id], onDelete: Cascade)
  quizzes Quiz[]
}

model Quiz {
  id             String   @id @default(uuid())
  title String
  quizRoomId String 
  quizRoom QuizRoom @relation(fields: [quizRoomId], references: [id], onDelete: Cascade)
  question Question[]
  finish Boolean @default(false)
}

model Question {
  id             String   @id @default(uuid())
  question String
  options Json
  correctAnswer String
  score Int?
  userAnswer String?

  quizId String
  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)
}

model ChatRoom {
  id             String   @id @default(uuid())
  name String @default("Chat")
  roomid String @unique
  room Room @relation(fields: [roomid], references: [id], onDelete: Cascade)

  messages Message[]
}

model File {  
  id        String   @id @default(uuid())
  fileName  String
  filePath  String
  size      Int
  roomId    String
  createdAt DateTime @default(now())
  room      Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
}

model Message {
  id String @id @default(uuid())
  content String @db.Text
  role ROLE @default(USER)
  roomId String
  room ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

enum MODE {
  CHAT
  QUIZ
}

enum ROLE {
  USER
  BOT
}